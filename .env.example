# Konfigurasi Portofolio Mucaa
# Copy file ini ke .env.local dan sesuaikan dengan informasi Anda

# Informasi Situs
REACT_APP_SITE_TITLE=Mucaa Portfolio
REACT_APP_SITE_DESCRIPTION=Web Developer & Creative Designer

# Biodata
REACT_APP_NAME=Mucaa
REACT_APP_TAGLINE=Full Stack Developer
REACT_APP_BIO=Passionate developer with expertise in web technologies, always learning and creating amazing digital experiences.
REACT_APP_EMAIL=mucaa@example.com
REACT_APP_LOCATION=Indonesia

# Sosial Media (username saja, tanpa @ atau URL)
REACT_APP_GITHUB_USERNAME=mucaa
REACT_APP_LINKEDIN_USERNAME=mucaa
REACT_APP_INSTAGRAM_USERNAME=mucaa

# Tema (gunakan hex color code)
REACT_APP_PRIMARY_COLOR=#6366f1
REACT_APP_SECONDARY_COLOR=#8b5cf6
REACT_APP_BACKGROUND_COLOR=#0f172a
REACT_APP_TEXT_COLOR=#f1f5f9

# Path Artikel (jangan ubah kecuali Anda tahu apa yang dilakukan)
REACT_APP_ARTICLES_PATH=/artikle
